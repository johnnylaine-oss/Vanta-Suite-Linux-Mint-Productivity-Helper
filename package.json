{
  "name": "vanta-suite",
  "version": "1.0.0",
  "description": "A keyboard-first productivity suite for Linux Mint Cinnamon",
  "author": "Vanta Suite",
  "main": "src/main/daemon.js",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnnylaine/Vanta-Suite-Linux-Mint-Productivity-Helper"
  },
  "bugs": {
    "url": "https://github.com/johnnylaine/Vanta-Suite-Linux-Mint-Productivity-Helper/issues"
  },
  "homepage": "https://github.com/johnnylaine/Vanta-Suite-Linux-Mint-Productivity-Helper#readme",
  "keywords": [
    "productivity",
    "linux-mint",
    "electron",
    "vue",
    "keyboard-shortcuts",
    "clipboard-manager",
    "terminal",
    "command-palette",
    "workflow-automation",
    "plugin-system"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --linux AppImage",
    "build:renderer": "vite build",
    "build:electron": "electron-builder --dir",
    "start": "electron .",
    "lint": "echo 'Linting not yet configured — add ESLint to devDependencies'",
    "check": "npx vite build --logLevel error"
  },
  "dependencies": {
    "fuse.js": "^7.0.0",
    "node-pty": "^1.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.vanta-suite.app",
    "productName": "Vanta Suite",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "src/core/**/*",
      "src/config/**/*",
      "data/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
